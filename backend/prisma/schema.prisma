datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  IT_OFFICER
  VIEWER
}

enum GeneralStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

enum AssignmentStatus {
  ACTIVE
  RETURNED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model User {
  id           String        @id @default(uuid())
  fullName     String
  email        String        @unique
  passwordHash String
  role         Role          @default(VIEWER)
  status             GeneralStatus @default(ACTIVE)
  mustChangePassword Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Department {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  status      GeneralStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employees   Employee[]
  assets      Asset[]
}

model Location {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  status      GeneralStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employees   Employee[]
  assets      Asset[]
}

model Employee {
  id           String        @id @default(uuid())
  employeeCode String        @unique 
  fullName     String
  email        String?       
  designation  String?
  phone        String?
  
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id])
  
  locationId   String?
  location     Location?     @relation(fields: [locationId], references: [id])
  
  status       GeneralStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  assignedAssets Asset[]           @relation("DirectAssignment")
  assignments    AssetAssignment[]
  supportTickets SupportTicket[]
}

model Asset {
  id                 String      @id @default(uuid())
  assetCode          String      @unique 
  deviceType         String
  brand              String?
  model              String
  serialNumber       String      @unique
  processor          String?
  ram                String?
  storage            String?
  operatingSystem    String?
  vendor             String?
  purchaseDate       DateTime?
  warrantyStatus     String
  warrantyExpiryDate DateTime?
  condition          String
  status             AssetStatus @default(AVAILABLE)
  
  macAddress         String?
  ipAddress          String?
  
  locationId         String?
  location           Location?   @relation(fields: [locationId], references: [id])
  
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])
  
  assignedEmployeeId String?
  assignedEmployee   Employee?   @relation("DirectAssignment", fields: [assignedEmployeeId], references: [id])
  
  qrCodeUrl          String?
  imageUrl           String?
  remarks            String?
  
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  assignments        AssetAssignment[]
  maintenanceLogs    MaintenanceLog[]
  documents          AssetDocument[]
  supportTickets     SupportTicket[]
}

model AssetAssignment {
  id            String           @id @default(uuid())
  
  assetId       String
  asset         Asset            @relation(fields: [assetId], references: [id])
  
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id])
  
  assignedDate  DateTime         @default(now())
  returnedDate  DateTime?
  status        AssignmentStatus @default(ACTIVE)
  remarks       String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model MaintenanceLog {
  id               String            @id @default(uuid())
  
  assetId          String
  asset            Asset             @relation(fields: [assetId], references: [id])
  
  issueDescription String
  repairAction     String?
  vendor           String?
  repairCost       Float?
  repairDate       DateTime?
  status           MaintenanceStatus @default(OPEN)
  remarks          String?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model SystemSettings {
  id                 String   @id @default("global")
  assetCodePrefix    String   @default("AST")
  warrantyPeriod     Int      @default(12)
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  userName    String?
  userRole    String?
  action      String
  module      String
  entityType  String?
  entityId    String?
  entityCode  String?
  oldValue    String?
  newValue    String?
  description String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model AssetTimeline {
  id              String   @id @default(uuid())
  assetId         String
  assetCode       String
  eventType       String
  title           String
  description     String?
  oldStatus       String?
  newStatus       String?
  employeeId      String?
  employeeName    String?
  departmentId    String?
  departmentName  String?
  locationId      String?
  locationName    String?
  performedById   String?
  performedByName String?
  createdAt       DateTime @default(now())
}

model AssetDocument {
  id              String   @id @default(uuid())
  
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  documentName    String
  documentType    String
  filePath        String
  fileSize        Int
  uploadedBy      String?
  uploadedByName  String?
  
  createdAt       DateTime @default(now())
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id          String         @id @default(uuid())
  ticketCode  String         @unique
  subject     String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])
  
  assetId     String?
  asset       Asset?         @relation(fields: [assetId], references: [id])
  
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
